# Environment variables for Fashion Detection System

# API Keys
WANDB_API_KEY=your_wandb_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=fashion-detection

# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCS_BUCKET_NAME=fashion-detection

# Azure Configuration
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_CONTAINER_NAME=fashion-detection

# Database Configuration
MONGO_URI=mongodb://localhost:27017/fashion_detection
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://user:password@localhost:5432/fashion_db

# Model Configuration
MODEL_CACHE_DIR=/path/to/model/cache
CLIP_MODEL_NAME=ViT-B/32
YOLO_MODEL_NAME=yolov8x

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/fashion_detection.log

# Performance Configuration
CUDA_VISIBLE_DEVICES=0,1
OMP_NUM_THREADS=4
TORCH_NUM_THREADS=4

# Security
SECRET_KEY=your_secret_key_here
API_KEY=your_api_key_here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Feature Flags
ENABLE_GPU=true
ENABLE_MIXED_PRECISION=true
ENABLE_CACHING=true
ENABLE_MONITORING=true

# External Services
SENTRY_DSN=your_sentry_dsn_here
ELASTICSEARCH_URL=http://localhost:9200
PROMETHEUS_PORT=9090